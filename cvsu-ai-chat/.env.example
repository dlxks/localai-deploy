# CvSU-AI VSCode Chat — credentials template. Safe to commit/share.
# Copy this file to ".env" and fill in your own values.
#
# Get your own API key by logging in at http://localhost:8081/app/chat
# (GitHub login) and creating a key, or ask the LocalAIS admin.

LOCALAI_BASE_URL=http://localhost:8081
LOCALAI_API_KEY=
LOCALAI_MODEL=gpt-3.5-turbo
