# GitHub OAuth app (https://github.com/settings/developers)
# Homepage URL: http://localhost:8081
# Authorization callback URL: http://localhost:8081/oauth/callback
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

# Public URL users open in browser during GitHub SSO.
LOCALAI_BASE_URL=http://localhost:8081

# Host port that maps to LocalAI container port 8080.
LOCALAI_PORT=8081

# LocalAI API key used by clients that call /v1 endpoints.
LOCALAI_API_KEY=sk-change-me
